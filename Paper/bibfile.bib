@incollection{algee-hewittEmbeddedIdeasRevolutionary2023,
  title = {Embedded {{Ideas}}: {{Revolutionary Theory}} and {{Political Science}} in the {{Eighteenth Century}}},
  shorttitle = {Embedded {{Ideas}}},
  booktitle = {Explorations in the {{Digital History}} of {{Ideas}}: {{New Methods}} and {{Computational Approaches}}},
  author = {{Algee-Hewitt}, Mark},
  editor = {{de Bolla}, Peter},
  year = {2023},
  pages = {225--255},
  publisher = {Cambridge University Press},
  address = {Cambridge},
  doi = {10.1017/9781009263610.011},
  urldate = {2023-11-20},
  abstract = {Using a new visualisation technique for word embedding data, this chapter explores the formation of complex, compound concepts in the late eighteenth century, focusing specifically on ‘political revolution’. Word embedding models offer an alternative method of understanding relationships between terms, both as a function of proximity (as in collocation) and of shared contexts (as in synonyms). By measuring the direct distance within the embedding space between two words over time in a series of aligned models, we can witness two parts of a compound idea bind together and observe which terms provide the binding force between them. Using this method, I explore the way that ‘revolution’ travels across the eighteenth century in relation to the ‘political’. Although loosely linked in the wake of the Glorious Revolution at the outset of the century, revolution becomes heavily tied to Newtonian mechanics, before being pulled back into political usage during the French Revolution. The method I introduce here reveals the hidden connections to ‘science’ in both political and revolution that undergirds their eventual merger into the idea of ‘political revolution’ that we have inherited today.},
  isbn = {978-1-00-926361-0},
  keywords = {compound concept,Locke,political science,political theory,rebellion,revolution,word embeddings},
  file = {C:\Users\marquexa\Zotero\storage\QBMB6UED\Algee-Hewitt - 2023 - Embedded Ideas Revolutionary Theory and Political.pdf}
}

@article{alonso-munozAppealEmotionsDiscourse2023,
