@article{shellmanShiftingSandsExplaining2013,
  title = {Shifting Sands {{Explaining}} and Predicting Phase Shifts by Dissident Organizations},
  author = {Shellman, Stephen M. and Levey, Brian P. and Young, Joseph K.},
  year = {2013},
